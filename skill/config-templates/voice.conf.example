# paired voice config (example — copy to ~/.config/paired/voice.conf)
# Generated by: paired-voice-setup.py init

# Voice cloning HTTP services (built via skill/engines Dockerfiles)
VOXCPM_URL=http://localhost:8056
XTTS_URL=http://localhost:8055

# Reference WAV (your voice) — populated by paired-voice-setup.py reference
# Local filesystem path:
VOICE_REFERENCE=/home/USER/.config/paired/voice/reference.wav

# Path the SERVICE container sees (because the file is bind-mounted into
# the container at /refs). If you ran your container without mounts, set
# this equal to VOICE_REFERENCE.
VOICE_REFERENCE_SERVICE=/refs/reference.wav

# Word-clips folder for splicing — every *.wav becomes a splice on its filename
# e.g.  myname.wav  -> the text "myname" anywhere triggers splicing
WORD_CLIPS_DIR=/home/USER/.config/paired/voice/word-clips

# Final-fallback piper voice (if VoxCPM2 and XTTS both unavailable)
FALLBACK_PIPER_VOICE=en_GB-northern_english_male-medium
